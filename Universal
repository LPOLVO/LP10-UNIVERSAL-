-- [ SCRIPT CARD BUILDER ]
-- ============================================================
local function MakeCard(data, order)
    local card = Btn(ScrollFrame, {
        Name             = data.Name,
        Size             = UDim2.new(1, 0, 0, 58),
        BackgroundColor3 = Config.Card,
        Text             = "",
        LayoutOrder      = order,
        ZIndex           = 7,
        AutoButtonColor  = false,
    })
    Corner(card, 14)

    if data.New then
        Stroke(card, Config.NewBadge, 1.5)
    else
        Stroke(card, Color3.fromRGB(32, 32, 50), 1)
    end

    -- Accent left bar
    local bar = Frame(card, {
        Size             = UDim2.new(0, 3, 1, -16),
        Position         = UDim2.new(0, 8, 0, 8),
        BackgroundColor3 = data.New and Config.NewBadge or Config.Accent,
        ZIndex           = 8,
    })
    Corner(bar, 4)

    -- Script name
    Label(card, {
        Size     = UDim2.new(1, -56, 1, 0),
        Position = UDim2.new(0, 20, 0, 0),
        Text     = data.Name,
        TextColor3 = Config.TextMain,
        Font     = Enum.Font.GothamSemibold,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        ZIndex   = 8,
    })

    -- NEW badge
    if data.New then
        local badge = Frame(card, {
            Size             = UDim2.new(0, 40, 0, 18),
            Position         = UDim2.new(1, -48, 0.5, -9),
            BackgroundColor3 = Config.NewBadge,
            ZIndex           = 9,
        })
        Corner(badge, 9)
        Label(badge, {
            Size = UDim2.new(1,0,1,0),
            Text = "NEW",
            TextColor3 = Color3.new(1,1,1),
            Font = Enum.Font.GothamBold,
            TextSize = 9,
            ZIndex = 10,
        })
    else
        -- Arrow indicator
        Label(card, {
            Size     = UDim2.new(0, 24, 0, 24),
            Position = UDim2.new(1, -32, 0.5, -12),
            Text     = "›",
            TextColor3 = Color3.fromRGB(60, 60, 90),
            Font     = Enum.Font.GothamBold,
            TextSize = 22,
            ZIndex   = 8,
        })
    end

    -- Hover / press animations
    card.MouseEnter:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            {BackgroundColor3 = Config.CardHover}):Play()
    end)
    card.MouseLeave:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            {BackgroundColor3 = Config.Card}):Play()
    end)
    card.MouseButton1Down:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(35, 35, 55)}):Play()
    end)
    card.MouseButton1Up:Connect(function()
        TweenService:Create(card, TweenInfo.new(0.1), {BackgroundColor3 = Config.CardHover}):Play()
    end)

    card.MouseButton1Click:Connect(function()
        PlaySound(Sounds.Click)
        if sheetOpen then CloseSheet(); task.wait(0.2) end
        OpenSheet(data)
    end)

    return card
end

