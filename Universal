local sheetOpen   = false
local currentData = nil

local function OpenSheet(data)
    if sheetOpen then return end
    sheetOpen   = true
    currentData = data

    PlaySound(Sounds.Sheet)
    SheetTitle.Text      = data.Name
    SheetNewBadge.Visible = data.New == true

    -- slide up
    TweenService:Create(Sheet, TweenInfo.new(0.42, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()
end

local function CloseSheet()
    if not sheetOpen then return end
    sheetOpen = false
    PlaySound(Sounds.Close)
    TweenService:Create(Sheet, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
        Position = UDim2.new(0, 0, 1, 10)
    }):Play()
end

BackBtn.MouseButton1Click:Connect(function()
    PlaySound(Sounds.Click)
    CloseSheet()
end)

ExecBtn.MouseButton1Click:Connect(function()
    if not currentData then return end
    PlaySound(Sounds.Execute)
    -- pulse animation on button
    TweenService:Create(ExecBtn, TweenInfo.new(0.1), {BackgroundColor3 = Config.Green}):Play()
    task.wait(0.12)
    TweenService:Create(ExecBtn, TweenInfo.new(0.1), {BackgroundColor3 = Config.Accent}):Play()
    -- notify & execute
    local name   = currentData.Name
    local source = currentData.Source
    SendLog(name)
    CustomNotify("⚡ Executing", name, Config.Green)
    task.wait(0.8)
    -- close everything
    CloseSheet()
    task.wait(0.4)
    TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size     = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
    }):Play()
    TweenService:Create(Blur, TweenInfo.new(0.4), {Size = 0}):Play()
    task.wait(0.45)
    pcall(function() Blur.Enabled = false; ScreenGui:Destroy() end)
    loadstring(source)()
end)

