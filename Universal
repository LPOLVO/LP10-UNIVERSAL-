local function ToggleUI(state)
    if state then
        Main.Visible = true; Blur.Enabled = true
        TweenService:Create(Main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 400, 0, 450), Position = UDim2.new(0.5, -200, 0.5, -225)}):Play()
        TweenService:Create(Blur, TweenInfo.new(0.5), {Size = 20}):Play()
    else
        TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
        local b = TweenService:Create(Blur, TweenInfo.new(0.4), {Size = 0}); b:Play()
        b.Completed:Connect(function() Blur.Enabled = false; Main.Visible = false end)
    end
end

