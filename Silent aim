local currentSize = Main.Size
ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        _G.IsResizing = true
        local dragStart, startSize = input.Position, Main.Size
        local connection
        connection = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                local delta = input.Position - dragStart
                local newX = math.clamp(startSize.X.Offset + delta.X, Config.MinSize.X, Config.MaxSize.X)
                local newY = math.clamp(startSize.Y.Offset + delta.Y, Config.MinSize.Y, Config.MaxSize.Y)
                Main.Size = UDim2.new(0, newX, 0, newY)
                currentSize = Main.Size
            end
        end)
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then _G.IsResizing = false connection:Disconnect() end end)
    end
end)

